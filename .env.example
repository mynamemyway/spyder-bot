# This is an example file. Copy it to .env and fill in your actual values.
# The .env file is ignored by Git (see .gitignore).

# Telegram Bot Token from @BotFather
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# OpenRouter API Key from https://openrouter.ai/keys
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# The base URL for the OpenRouter API
OPENROUTER_API_BASE="https://openrouter.ai/api/v1"

# The specific chat model to use from OpenRouter
OPENROUTER_CHAT_MODEL="model"

# The fallback model to use if the primary model fails
OPENROUTER_FALLBACK_MODEL= "reserve_model"

# URL for the self-hosted embedding service API
EMBEDDING_SERVICE_URL="http://your_server_ip:8000/embed"

# (Optional) Controls the creativity of the response (e.g., 0.7).
OPENROUTER_TEMPERATURE=0.7

# (Optional) Limits the length of the generated response in tokens (e.g., 1024).
OPENROUTER_MAX_TOKENS=1024

# (Optional) The number of recent messages to keep in the conversation memory window.
MEMORY_WINDOW_SIZE=10

# Determines if the bot's response should be sanitized (###)
SANITIZE_RESPONSE=True

# (Optional) Path to the welcome photo for the /start command
WELCOME_PHOTO_PATH="assets/welcome_photo.png"

# (Optional) Path to the help photo for the /help command
HELP_PHOTO_PATH="assets/help_photo.png"

# (Optional) Path to the catalog photo for the /catalog command
CATALOG_PHOTO_PATH="assets/catalog_photo.png"

# (Optional) Path to the price calculation photo
CALCULATION_PHOTO_PATH="assets/calculate_photo.png"

# (Optional) Path to the banners photo for the material selection step
BANNERS_PHOTO_PATH="assets/banners_photo.png"

# (Optional) Path to the order confirmation photo
ORDER_PHOTO_PATH="assets/order_photo.png"

# (Optional) URL for the manager's Telegram contact
MANAGER_TELEGRAM_URL="https://t.me/username"

# Chat ID of the manager to send order notifications to
MANAGER_CHAT_ID="manager_tg_id/chat_id"

# (Optional) System prompt for the RAG chain.
# It defines the persona and rules for the AI assistant.
SYSTEM_PROMPT="Ты — экспертный продавец-консультант в типографии `Пиранья`. Твоя главная задача — помогать клиентам выбирать и заказывать продукцию баннеры.

Правила общения:
1.  **Будь экспертом:** Отвечай на вопросы, используя *только* предоставленный тебе 'Контекст из базы знаний'. Не придумывай характеристики, цены или сроки, которых нет в контексте.
2.  **Веди клиента:** Твоя цель — не просто ответить, а провести клиента по воронке: помочь с выбором продукта, материала, размера и других опций. Задавай уточняющие вопросы, чтобы лучше понять задачу клиента. Например: 'Для каких целей вам нужен баннер? На улице или в помещении?'
3.  **Будь проактивным:** Если клиент задает общий вопрос, предоставь краткий ответ и сразу предложи следующий логический шаг. Например, после ответа о материалах предложи выбрать размер.
4.  **Если не знаешь - не придумывай:** Если в контексте нет ответа на вопрос, вежливо сообщи, что не обладаешь этой информацией, и предложи связаться с менеджером для уточнения деталей.
5.  **Форматирование:** Используй Markdown для структурирования ответа: списки, жирный шрифт для акцентов.
6.  **Стиль:** Общайся вежливо, дружелюбно и профессионально. Ты — лицо компании 'Пиранья'."
